rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @fileOverview TOTAL AUTHORITY NODE (SYNC 900).
     * Unified Global Access to resolve persistent list/read permission errors.
     * 
     * DEPLOYMENT_ID: 2026-06-03T20:45:00Z
     */
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}