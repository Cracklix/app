
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'arshdeepgrewal1122@gmail.com' ||
        getUserData().role in ['ADMIN', 'SUPER_ADMIN']
      );
    }

    function isContentTeam() {
      return isAdmin() || (isAuthenticated() && getUserData().role in ['CONTENT_MANAGER', 'QUESTION_REVIEWER', 'CURRENT_AFFAIRS_EDITOR']);
    }

    function isSupport() {
      return isAdmin() || (isAuthenticated() && getUserData().role in ['SUPPORT_AGENT', 'QUESTION_REVIEWER']);
    }

    // --- Publicly Readable Institutional Data ---
    // These collections are accessible by anyone for browsing the catalog and analysis.
    match /boards/{id} { allow read: if true; allow write: if isAdmin(); }
    match /exams/{id} { allow read: if true; allow write: if isAdmin(); }
    match /subjects/{id} { allow read: if true; allow write: if isContentTeam(); }
    match /mocks/{id} { allow read: if true; allow write: if isContentTeam(); }
    match /current_affairs/{id} { allow read: if true; allow write: if isContentTeam(); }
    match /notifications/{id} { allow read: if true; allow write: if isContentTeam(); }
    match /pyqs/{id} { allow read: if true; allow write: if isContentTeam(); }
    match /settings/{id} { allow read: if true; allow write: if isAdmin(); }

    // --- Authenticated Student Data ---
    match /questions/{id} { 
      allow read: if isAuthenticated(); 
      allow create: if isContentTeam();
      allow update: if isContentTeam();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || isSupport());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /reports/{id} { 
      allow create: if isAuthenticated(); 
      allow read, update: if isSupport() || isAdmin(); 
      allow delete: if isAdmin();
    }

    match /bookmarks/{id} { 
      allow read, write: if isAuthenticated() && request.resource.data.userId == request.auth.uid; 
    }

    match /test_sessions/{id} { 
      allow read, write: if isAuthenticated() && (id.startsWith(request.auth.uid) || isAdmin()); 
    }

    match /results/{id} { 
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()); 
      allow create: if isAuthenticated(); 
    }
    
    match /support_tickets/{id} {
      allow create: if true;
      allow read, update, delete: if isSupport() || isAdmin();
    }

    match /audit_logs/{id} { 
      allow read: if isAdmin(); 
      allow create: if isContentTeam() || isSupport(); 
    }

    // Global admin fallback for the founder
    match /{document=**} {
      allow read, write: if request.auth.token.email == 'arshdeepgrewal1122@gmail.com';
    }
  }
}
