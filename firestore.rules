rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @fileOverview TOTAL AUTHORITY NODE (SYNC 300).
     * This rule set grants global read/write access to ensure all 16 collections 
     * are synchronized with the Management Portal.
     * 
     * DEPLOYMENT_ID: 2026-06-03T16:45:00Z
     */
    match /{document=**} {
      allow read, write: if true;
    }
  }
}