rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @fileOverview Enterprise RBAC Security Protocol v1.0.
     * Hardened for 10k+ Aspirants with strict ownership and authority gates.
     */

    // Helper: Verify if the request is from a legitimate authenticated node
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check for Administrative Authority
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['ADMIN', 'SUPER_ADMIN'];
    }

    // Helper: Verify Resource Ownership
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- 1. Master Registry (Official Content) ---
    match /boards/{boardId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /exams/{examId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /questions/{qId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /passes/{passId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /notes/{noteId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /current_affairs/{caId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /free_content/{fcId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /notifications/{nId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- 2. Aspirant Registry (Private Nodes) ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /attempts/{attemptId} {
      // attemptId format is {userId}_{mockId}
      allow read, write: if isAuthenticated() && (attemptId.split('_')[0] == request.auth.uid || isAdmin());
    }

    match /results/{resultId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /bookmarks/{bId} {
      allow read, write: if isAuthenticated() && (resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }

    // --- 3. Management Registry (Audit & Support) ---
    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }
    match /payment_requests/{reqId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin() || (resource.data.userId == request.auth.uid);
    }
    match /payments/{pId} {
      allow read: if isAdmin() || (resource.data.userId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }
    match /support_tickets/{ticketId} {
      allow create: if true; // Public access for contact form
      allow read, update, delete: if isAdmin();
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ads/{adId} {
      allow read: if true;
      allow write: if true; // impressions/clicks incrementation allowed
    }
  }
}