
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // CRACKLIX PRODUCTION HARDENING V4
    // Institutional Grade Security Rules

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        getUserData().role == 'ADMIN' ||
        getUserData().role == 'SUPER_ADMIN'
      );
    }

    // --- Core Schemas ---

    match /users/{userId} {
      // Students can read their own profile. Admins can read all for support.
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      // Only the user or an admin can update profile data.
      allow write: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    match /boards/{docId} {
      allow read: if true; // Public catalog
      allow write: if isAdmin();
    }

    match /exams/{docId} {
      allow read: if true; // Public catalog
      allow write: if isAdmin();
    }

    match /subjects/{docId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /questions/{docId} {
      // Questions are readable by authenticated students (to take tests) 
      // but write is strictly for admin/super-admin (IP Protection).
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /mocks/{docId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /results/{resultId} {
      // Students only see their own performance metrics.
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /test_sessions/{sessionId} {
      // Session persistence logic (Auto-Save)
      allow read, write: if isAuthenticated() && (request.auth.uid in sessionId || isAdmin());
    }

    match /current_affairs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reports/{docId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /bookmarks/{docId} {
      allow read, write: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
